<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style x:Key="GalleryPrimaryButtonStyle" TargetType="Button">
    <Setter Property="FontFamily" Value="{StaticResource PrimaryFontFamily}" />
    <Setter Property="Background" Value="{ThemeResource AccentStrongBrush}" />
    <Setter Property="Foreground" Value="{ThemeResource OnPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource AccentStrongBrush}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius8}" />
    <Setter Property="Padding" Value="16,10" />
  </Style>

  <Style x:Key="GallerySecondaryButtonStyle" TargetType="Button">
    <Setter Property="FontFamily" Value="{StaticResource PrimaryFontFamily}" />
    <Setter Property="Background" Value="{ThemeResource SurfaceElevatedBrush}" />
    <Setter Property="Foreground" Value="{ThemeResource TextBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius8}" />
    <Setter Property="Padding" Value="16,10" />
  </Style>

  <Style x:Key="GalleryGhostButtonStyle" TargetType="Button">
    <Setter Property="FontFamily" Value="{StaticResource PrimaryFontFamily}" />
    <Setter Property="Background" Value="{ThemeResource TransparentChromeBrush}" />
    <Setter Property="Foreground" Value="{ThemeResource AccentBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource AccentMutedBrush}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius8}" />
    <Setter Property="Padding" Value="16,10" />
  </Style>

  <Style x:Key="GalleryDestructiveButtonStyle" TargetType="Button">
    <Setter Property="FontFamily" Value="{StaticResource PrimaryFontFamily}" />
    <Setter Property="Background" Value="{ThemeResource DestructiveStrongBrush}" />
    <Setter Property="Foreground" Value="{ThemeResource OnPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource DestructiveStrongBrush}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius8}" />
    <Setter Property="Padding" Value="16,10" />
  </Style>

  <Style x:Key="GalleryCardChromeStyle" TargetType="Border">
    <Setter Property="Background" Value="{ThemeResource SurfaceElevatedBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius12}" />
    <Setter Property="Padding" Value="{StaticResource Space16}" />
  </Style>

  <Style x:Key="GalleryChipChromeStyle" TargetType="Border">
    <Setter Property="Background" Value="{ThemeResource SurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius16}" />
    <Setter Property="Padding" Value="12,6" />
  </Style>

  <Style x:Key="GalleryNavHostStyle" TargetType="Border">
    <Setter Property="UseLayoutRounding" Value="True" />
    <Setter Property="Background" Value="{ThemeResource SurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="0,0,1,0" />
    <Setter Property="Padding" Value="{StaticResource Space16}" />
  </Style>

  <!-- Minimal ListBoxItem: avoids Fluent reveal / semi-transparent selection layers that rasterize poorly on Skia WASM. -->
  <Style x:Key="GallerySectionNavListBoxItemStyle" TargetType="ListBoxItem">
    <Setter Property="Padding" Value="8,6" />
    <Setter Property="MinHeight" Value="44" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="UseLayoutRounding" Value="True" />
    <Setter Property="Background" Value="{ThemeResource TransparentChromeBrush}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ListBoxItem">
          <Border x:Name="LayoutRoot"
                  Background="{ThemeResource TransparentChromeBrush}"
                  UseLayoutRounding="True">
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="SelectionStates">
                <VisualState x:Name="Unselected" />
                <VisualState x:Name="Selected">
                  <VisualState.Setters>
                    <Setter Target="LayoutRoot.Background" Value="{ThemeResource HoverBrush}" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="SelectedUnfocused">
                  <VisualState.Setters>
                    <Setter Target="LayoutRoot.Background" Value="{ThemeResource HoverBrush}" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              Margin="{TemplateBinding Padding}" />
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
