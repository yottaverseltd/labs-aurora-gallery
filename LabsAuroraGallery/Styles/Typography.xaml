<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- System-first: Skia WASM + Inter variable/font bugs should never replace OS text with garbage. -->
  <FontFamily x:Key="PrimaryFontFamily">system-ui, -apple-system, ui-sans-serif, 'Segoe UI', Inter, sans-serif</FontFamily>

  <Style x:Key="HeroText" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource PrimaryFontFamily}" />
    <Setter Property="FontSize" Value="{StaticResource FontSize56}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="CharacterSpacing" Value="-20" />
    <Setter Property="Foreground" Value="{ThemeResource TextBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style x:Key="TitleText" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource PrimaryFontFamily}" />
    <Setter Property="FontSize" Value="{StaticResource FontSize24}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="CharacterSpacing" Value="-10" />
    <Setter Property="Foreground" Value="{ThemeResource TextBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style x:Key="EyebrowText" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource PrimaryFontFamily}" />
    <Setter Property="FontSize" Value="{StaticResource FontSize11}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="CharacterSpacing" Value="120" />
    <Setter Property="Foreground" Value="{ThemeResource TextMutedBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style x:Key="BodyText" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource PrimaryFontFamily}" />
    <Setter Property="FontSize" Value="{StaticResource FontSize16}" />
    <Setter Property="Foreground" Value="{ThemeResource TextBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style x:Key="MutedText" TargetType="TextBlock" BasedOn="{StaticResource BodyText}">
    <Setter Property="Foreground" Value="{ThemeResource TextMutedBrush}" />
  </Style>

  <Style x:Key="CaptionText" TargetType="TextBlock" BasedOn="{StaticResource BodyText}">
    <Setter Property="FontSize" Value="{StaticResource FontSize12}" />
    <Setter Property="Foreground" Value="{ThemeResource TextMutedBrush}" />
  </Style>

  <Style x:Key="ChatBubbleText" TargetType="TextBlock" BasedOn="{StaticResource BodyText}">
    <Setter Property="FontSize" Value="{StaticResource FontSize14}" />
  </Style>

</ResourceDictionary>
